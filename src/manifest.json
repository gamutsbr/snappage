{
  "manifest_version": 3,
  "name": "SnapPage – Full Page Screenshot",
  "version": "1.0.0",
  "description": "Capture screenshots of full pages — mesmo além do que aparece na tela. Download ou copia direto.",
  "permissions": [
    "activeTab",
    "debugger",
    "downloads",
    "scripting",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
